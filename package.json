    "expo-camera": "~55.0.9",
    "expo-print": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-text-extractor": "^2.0.0",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest-expo": "^55.0.9",
    "typescript": "~5.9.2"
  },
