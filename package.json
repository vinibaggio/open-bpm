{
  "name": "bloodpressure-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg|victory-native|victory-.*|@react-native-async-storage/.*|d3-.*)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~55.0.6",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-print": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "uuid": "^13.0.0",
    "victory-native": "^41.20.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "typescript": "~5.9.2"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/vinibaggio/bloodpressure.git"
